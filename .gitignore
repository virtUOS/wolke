# Go
/bin/
*.test
*.out
coverage.*

# The embedded SPA: the real assets are generated by `vite build` and copied in
# at build time. A placeholder index.html IS committed so go:embed always has a
# target and `go build` works without a frontend build; everything else is build
# output and stays untracked.
/internal/web/dist/*
!/internal/web/dist/index.html

# Frontend
/web-ui/node_modules/
/web-ui/dist/
/web-ui/.vite/
/web-ui/coverage/

# Local config & secrets (examples ARE committed; real ones are not)
.env
*.local.yaml

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# design-sync scratch / build output / machine state
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
.design-sync/wolke-ds.css
