# Copy to .env for local development. These are SCALAR settings and secrets;
# they override config.yaml and the built-in defaults (precedence: env > file >
# defaults — docs/02 §11). Structured maps (OIDC claim mapping, branding theme)
# live in config.yaml, not here.

# --- Core ---
# Public URL the app is reached at. Used to build the OIDC redirect_uri and to
# decide Secure cookies. This MUST match the EXACT origin your browser uses
# (host included — localhost and 127.0.0.1 are different cookie hosts):
#   - embedded binary (make serve): browse http://localhost:8080
#   - Vite dev loop (browser hits Vite): the Vite origin, e.g. http://localhost:5180
# Note: this is independent of OIDC_ISSUER_URL below, which must use 127.0.0.1 for
# the server→mock calls regardless of what you browse.
PUBLIC_URL=http://localhost:8080

# Listen address for the Go server.
HTTP_ADDR=:8080

# debug | info | warn | error
LOG_LEVEL=debug

# Directory of mounted branding assets served at /branding/ (logos, favicon).
BRANDING_DIR=branding

# Optional path to the structured config file (OIDC claim mapping, branding).
# Leave unset to use built-in defaults (the UOS skin).
# CONFIG_FILE=config.yaml

# --- Database (matches `make db`) ---
DATABASE_URL=postgres://wolke:devpass@localhost:5432/wolke?sslmode=disable

# --- Secrets ---
# Signs the session cookie. Generate one: openssl rand -base64 32
SESSION_SECRET=dev-only-change-me

# Optional bearer token for /metrics. Leave UNSET in the normal deploy: Caddy
# 404s /metrics at the edge and the app port is internal-only, so Prometheus
# scrapes it over the trusted network without a secret. Set it (generate as
# above) only if the scrape path crosses an untrusted boundary. See README →
# "Metrics & monitoring".
# METRICS_TOKEN=

# Comma-separated proxy CIDRs allowed to set X-Forwarded-*. Empty in local dev
# (no proxy); set to Caddy's network in Compose/prod.
# TRUSTED_PROXIES=10.0.0.0/8

# --- OIDC (scalars here; claim mapping in config.yaml) ---
# Points at the local mock IdP from `make idp`. Without these the server runs in
# stub mode and the authenticated endpoints (/api/me, /api/catalog, …) are absent,
# so the SPA can't load. Use 127.0.0.1 (not localhost): the mock crashes on IPv6.
OIDC_ISSUER_URL=http://127.0.0.1:8455/default
OIDC_CLIENT_ID=wolke
OIDC_CLIENT_SECRET=dev-secret
OIDC_SCOPES=openid,profile,email

# --- Compose stack only (compose.yaml) ---
# These are read by Compose (it auto-loads this .env from the project root); they
# are not used by the `make run` loop. Both fail closed — `compose up` aborts if
# unset — so a deploy never silently runs with a default secret.
# Postgres superuser password for the stack's database.
POSTGRES_PASSWORD=change-me-in-compose
# Caddy ports. Rootless podman can't bind <1024 — override to high ports then.
# CADDY_HTTP_PORT=8080
# CADDY_HTTPS_PORT=8443
